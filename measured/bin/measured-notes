#!/usr/bin/env python3
"""Print a path inside this repo's persistent ticketing directory.

State lives under one dir per repo (namespaced by working directory, like
Claude Code's own projects/<encoded-cwd>/). That dir holds a `state.sqlite3`
plus a PLAN-NNNN directory per planning effort; completed plans move under
ARCHIVE/. Task IDs are unique across every plan in the repo.

Most targets act within a single plan, named with --plan REF (a number,
PLAN-7, etc.). --task-get is the exception: a task ID is globally unique, so
it resolves on its own.

Pass --set-plans-root DIR (or -R DIR) to use DIR as the plans root verbatim
(it holds the db, the plans, and ARCHIVE/). Omit it to derive the root from
Claude's working directory, as before.

  --plans-root [DIR]  print the plans root; with DIR, the root for that project
                      dir (`--plans-root .` = the current project), without
                      walking the process tree
  --plan-new          allocate the next PLAN-NNNN and print its dir
  --plan-dir REF      print a plan's dir (active or archived)
  --plan-archive REF    move a plan under ARCHIVE/, print its new dir
  --plan-unarchive REF  move it back out of ARCHIVE/, print its new dir
  --ticket REF        <plan>/TICKET.md
  --architecture REF  <plan>/ARCHITECTURE.md
  --implementation REF  <plan>/IMPLEMENTATION.md
  --task-new REF      create and print the next TASK-NNNN.md in the plan
  --task-get REF      print the full path of a task by its global ID

Path resolution lives in ../lib/session_lib.py; ID allocation in ../lib/db.py.
"""

import argparse
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent / "lib"))
import db  # noqa: E402
import session_lib  # noqa: E402

# The single-file targets that resolve to a well-known name within a plan.
FILE_TARGETS = {
    "ticket": "TICKET.md",
    "architecture": "ARCHITECTURE.md",
    "implementation": "IMPLEMENTATION.md",
}

# Marks `--plans-root` given without a DIR argument (vs. absent, which is None).
NO_DIR = object()


USAGE_TEXT = """\
usage: measured-notes [--set-plans-root DIR | -R DIR]
                      (--plans-root [DIR] | --plan-new | --plan-dir REF |
                       --plan-archive REF | --plan-unarchive REF |
                       --ticket REF | --architecture REF |
                       --implementation REF | --task-new REF | --task-get REF)
"""

HELP_TEXT = (
    USAGE_TEXT
    + """
Print a path inside this repo's persistent ticketing directory.

State is shared across every Claude session in the repo. It holds one
`state.sqlite3` plus a PLAN-NNNN directory per planning effort (one
ARCHITECTURE.md and its tasks); completed plans move under ARCHIVE/.

Plans root:
  -R, --set-plans-root DIR  use DIR as the plans root verbatim, rather than
                            deriving it from Claude's working directory
  --plans-root [DIR]        print the plans root; with DIR, the root for that
                            project dir (`--plans-root .` = the current
                            project), without walking the process tree

Plans:
  --plan-new            allocate the next PLAN-NNNN, print its dir
  --plan-dir REF        print a plan's dir (active or archived)
  --plan-archive REF    move a plan under ARCHIVE/, print its new dir
  --plan-unarchive REF  move it back out of ARCHIVE/, print its new dir

Within a plan (REF names the plan: a number, PLAN-7, ...):
  --ticket REF             <plan>/TICKET.md
  --architecture REF       <plan>/ARCHITECTURE.md
  --implementation REF     <plan>/IMPLEMENTATION.md
  --task-new REF           create and print the next TASK-NNNN.md

Tasks (global):
  --task-get REF           print the full path of a task by its global ID,
                           wherever its plan lives, or exit 1 if missing
"""
)


class _Parser(argparse.ArgumentParser):
    def format_help(self) -> str:
        return HELP_TEXT

    def format_usage(self) -> str:
        return USAGE_TEXT


def _plan_ref(parser, raw: str) -> int:
    plan_id = session_lib.parse_ref(raw, "PLAN")
    if plan_id is None:
        parser.error(f"not a plan reference: {raw!r}")
    return plan_id


def _resolve_plan_dir(parser, repo, plan_id: int) -> pathlib.Path:
    path = session_lib.plan_dir(repo, plan_id)
    if path is None:
        parser.error(f"no such plan: PLAN-{plan_id:04d}")
    return path


def main(argv: list[str]) -> int:
    parser = _Parser(prog="measured-notes", add_help=False)
    parser.add_argument("-h", "--help", action="help")
    parser.add_argument(
        "-R", "--set-plans-root", dest="set_plans_root", metavar="DIR"
    )

    group = parser.add_mutually_exclusive_group(required=True)
    # Optional DIR: `--plans-root .` prints the root for that project dir;
    # bare `--plans-root` prints the resolved root (honoring -R / process walk).
    # NO_DIR distinguishes "flag absent" (None) from "flag present, no arg".
    group.add_argument(
        "--plans-root", dest="plans_root", nargs="?", const=NO_DIR, metavar="DIR"
    )
    group.add_argument(
        "--plan-new", dest="action", action="store_const", const="plan-new"
    )
    group.add_argument("--plan-dir", dest="plan_dir", metavar="REF")
    group.add_argument("--plan-archive", dest="plan_archive", metavar="REF")
    group.add_argument("--plan-unarchive", dest="plan_unarchive", metavar="REF")
    group.add_argument("--ticket", dest="ticket", metavar="REF")
    group.add_argument("--architecture", dest="architecture", metavar="REF")
    group.add_argument("--implementation", dest="implementation", metavar="REF")
    group.add_argument("--task-new", dest="task_new", metavar="REF")
    group.add_argument("--task-get", dest="task_get", metavar="REF")

    args = parser.parse_args(argv)

    # `--plans-root DIR` prints the root for that project dir, standalone.
    if args.plans_root is not None and args.plans_root is not NO_DIR:
        print(session_lib.repo_dir_for_project(args.plans_root))
        return 0

    if args.set_plans_root is not None:
        repo = session_lib.repo_dir_at(args.set_plans_root)
    else:
        repo = session_lib.repo_dir()

    # Bare `--plans-root` prints the resolved root.
    if args.plans_root is NO_DIR:
        print(repo)
        return 0

    if args.action == "plan-new":
        conn = db.connect(repo)
        try:
            print(session_lib.new_plan(repo, conn))
        finally:
            conn.close()
        return 0

    if args.plan_dir is not None:
        pid = _plan_ref(parser, args.plan_dir)
        print(_resolve_plan_dir(parser, repo, pid))
        return 0

    if args.plan_archive is not None:
        pid = _plan_ref(parser, args.plan_archive)
        try:
            print(session_lib.archive_plan(repo, pid))
        except (FileNotFoundError, FileExistsError) as e:
            print(str(e), file=sys.stderr)
            return 1
        return 0

    if args.plan_unarchive is not None:
        pid = _plan_ref(parser, args.plan_unarchive)
        try:
            print(session_lib.unarchive_plan(repo, pid))
        except (FileNotFoundError, FileExistsError) as e:
            print(str(e), file=sys.stderr)
            return 1
        return 0

    if args.task_get is not None:
        task_id = session_lib.parse_ref(args.task_get, "TASK")
        if task_id is None:
            parser.error(f"not a task reference: {args.task_get!r}")
        conn = db.connect(repo)
        try:
            plan_id = db.task_plan(conn, task_id)
        finally:
            conn.close()
        path = None
        if plan_id is not None:
            plan = session_lib.plan_dir(repo, plan_id)
            if plan is not None:
                path = session_lib.resolve_task_file(plan, str(task_id))
        if path is None:
            print(f"no such task: {args.task_get}", file=sys.stderr)
            return 1
        print(path)
        return 0

    # The remaining targets all act within one plan named by their REF.
    for attr, target in (
        ("task_new", "task-new"),
        ("ticket", "ticket"),
        ("architecture", "architecture"),
        ("implementation", "implementation"),
    ):
        raw = getattr(args, attr)
        if raw is None:
            continue
        pid = _plan_ref(parser, raw)
        plan = _resolve_plan_dir(parser, repo, pid)

        if target == "task-new":
            conn = db.connect(repo)
            try:
                print(session_lib.new_task(plan, conn, pid))
            finally:
                conn.close()
            return 0

        print(plan / FILE_TARGETS[target])
        return 0

    # add_mutually_exclusive_group(required=True) guarantees we never reach here.
    parser.error("no target given")


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
