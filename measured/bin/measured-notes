#!/usr/bin/env python3
"""Print a path inside the per-Claude-session state directory.

The directory flags each print a directory and supersede any target.
Otherwise exactly one target is required. The single-file targets map to a
well-known file; the --task-* targets manage a series of numbered task files:

  --root-dir        the state root (holds every project's session dirs)
  --project-dir     this project's dir (holds every session dir for the repo)
  --session-dir     this session's dir (where the targets below live)
  --ticket          <session>/TICKET.md
  --architecture    <session>/ARCHITECTURE.md
  --implementation  <session>/IMPLEMENTATION.md
  --task-new        create and print the next <session>/TASK-NNN.md
  --task-list       print the basename of every TASK-NNN.md, in order
  --task-get REF    print the full path of a task (REF: 123, TASK-123,
                    or TASK-123.md), or exit 1 if it doesn't exist

Session-dir resolution lives in ../lib/session_lib.py.
"""

import argparse
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent / "lib"))
import session_lib  # noqa: E402

TARGETS = {
    "ticket": "TICKET.md",
    "architecture": "ARCHITECTURE.md",
    "implementation": "IMPLEMENTATION.md",
}


USAGE_TEXT = """\
usage: measured-notes (--root-dir | --project-dir | --session-dir | --ticket |
                       --architecture | --implementation | --task-new |
                       --task-list | --task-get REF)
"""

HELP_TEXT = (
    USAGE_TEXT
    + """
Print a path inside the per-Claude-session state directory.

Debugging (each prints a directory, superseding any target):
  --root-dir        the state root (holds every project's session dirs)
  --project-dir     this project's dir (holds every session dir for the repo)
  --session-dir     this session's dir (where the targets below live)

Single-file target (exactly one, unless a debugging flag is given):
  --ticket          <session>/TICKET.md
  --architecture    <session>/ARCHITECTURE.md
  --implementation  <session>/IMPLEMENTATION.md

Task series:
  --task-new        create and print the next <session>/TASK-NNN.md
  --task-list       print the basename of every TASK-NNN.md, in order
  --task-get REF    print the full path of a task (REF: 123, TASK-123,
                    or TASK-123.md), or exit 1 if it doesn't exist
"""
)


class _Parser(argparse.ArgumentParser):
    def format_help(self) -> str:
        return HELP_TEXT

    def format_usage(self) -> str:
        return USAGE_TEXT


def main(argv: list[str]) -> int:
    parser = _Parser(prog="measured-notes", add_help=False)
    parser.add_argument("-h", "--help", action="help")

    dirs = parser.add_mutually_exclusive_group()
    dirs.add_argument("--root-dir", dest="dir", action="store_const", const="root")
    dirs.add_argument(
        "--project-dir", dest="dir", action="store_const", const="project"
    )
    dirs.add_argument(
        "--session-dir", dest="dir", action="store_const", const="session"
    )

    group = parser.add_mutually_exclusive_group()
    group.add_argument(
        "--ticket", dest="target", action="store_const", const="ticket"
    )
    group.add_argument(
        "--architecture", dest="target", action="store_const", const="architecture"
    )
    group.add_argument(
        "--implementation", dest="target", action="store_const", const="implementation"
    )
    group.add_argument(
        "--task-new", dest="target", action="store_const", const="task-new"
    )
    group.add_argument(
        "--task-list", dest="target", action="store_const", const="task-list"
    )
    group.add_argument(
        "--task-get", dest="task_ref", metavar="REF", default=None
    )

    args = parser.parse_args(argv)

    if args.dir is not None:
        printers = {
            "root": session_lib.state_root,
            "project": session_lib.project_dir,
            "session": session_lib.session_dir,
        }
        print(printers[args.dir]())
        return 0

    if args.task_ref is not None:
        path = session_lib.resolve_task_file(session_lib.session_dir(), args.task_ref)
        if path is None:
            print(f"no such task: {args.task_ref}", file=sys.stderr)
            return 1
        print(path)
        return 0

    if args.target is None:
        parser.error(
            "exactly one target is required: --ticket, --architecture, "
            "--implementation, --task-new, --task-list, --task-get"
        )

    # The --task-* targets manage a series of numbered files: --task-new
    # allocates the next free TASK-NNN.md (creating it, race-free), --task-list
    # enumerates them. The remaining targets are fixed, well-known filenames.
    if args.target == "task-new":
        print(session_lib.allocate_task_file(session_lib.session_dir()))
        return 0

    if args.target == "task-list":
        for name in session_lib.list_task_files(session_lib.session_dir()):
            print(name)
        return 0

    print(session_lib.session_dir() / TARGETS[args.target])
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
