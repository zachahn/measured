#!/usr/bin/env python3
"""Print a path inside the per-Claude-session state directory.

With --root, print the state root that contains every project's session
directories (and ignore any target flag). Otherwise exactly one target flag
is required; each maps to a well-known file inside the session directory:

  --root            the state root (holds every project's session dirs)
  --ticket          <session>/TICKET.md
  --architecture    <session>/ARCHITECTURE.md
  --implementation  <session>/IMPLEMENTATION.md

Session-dir resolution lives in ../lib/session_lib.py.
"""

import argparse
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent / "lib"))
import session_lib  # noqa: E402

TARGETS = {
    "ticket": "TICKET.md",
    "architecture": "ARCHITECTURE.md",
    "implementation": "IMPLEMENTATION.md",
}


USAGE_TEXT = """\
usage: measured-notes (--root |
                       --ticket | --architecture | --implementation)
"""

HELP_TEXT = (
    USAGE_TEXT
    + """
Print a path inside the per-Claude-session state directory.

Root (supersedes every target; for debugging):
  --root            the state root (holds every project's session dirs)

Target (exactly one, unless --root is given):
  --ticket          <session>/TICKET.md
  --architecture    <session>/ARCHITECTURE.md
  --implementation  <session>/IMPLEMENTATION.md
"""
)


class _Parser(argparse.ArgumentParser):
    def format_help(self) -> str:
        return HELP_TEXT

    def format_usage(self) -> str:
        return USAGE_TEXT


def main(argv: list[str]) -> int:
    parser = _Parser(prog="measured-notes", add_help=False)
    parser.add_argument("-h", "--help", action="help")

    parser.add_argument("--root", action="store_true")

    group = parser.add_mutually_exclusive_group()
    group.add_argument(
        "--ticket", dest="target", action="store_const", const="ticket"
    )
    group.add_argument(
        "--architecture", dest="target", action="store_const", const="architecture"
    )
    group.add_argument(
        "--implementation", dest="target", action="store_const", const="implementation"
    )

    args = parser.parse_args(argv)

    if args.root:
        print(session_lib.state_root())
        return 0

    if args.target is None:
        parser.error(
            "exactly one target is required: "
            "--ticket, --architecture, --implementation"
        )

    print(session_lib.session_dir() / TARGETS[args.target])
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
