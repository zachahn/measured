#!/usr/bin/env python3
"""Locate this repo's plans, or start a new one.

The docs directory is determined by the repo's `docs-location` setting (set via
`measured-config --set docs-location <value>`). This setting is required; the
script exits with an error and remediation instructions if it is absent.

  (no arguments)        print the docs dir, creating it if absent
  --new-plan-dir SLUG   create `YYYY-MM-DD-<sanitized-slug>` and print its path

Build ticket/architecture/task paths by joining filenames to a plan dir
yourself (e.g. `<plan-dir>/TICKET.md`); this script does not resolve them.

Path/state resolution lives in ../lib/session_lib.py.
"""

import argparse
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent / "lib"))
import session_lib  # noqa: E402


HELP_TEXT = """\
usage: measured-notes [--new-plan-dir SLUG]

Locate this repo's plans, or start a new one.

The docs directory comes from the repo's `docs-location` setting. Set it with:
  measured-config --set docs-location XDG_STATE_HOME
  measured-config --set docs-location "REPO: path/to/docs"

  (no arguments)        print the absolute path of the docs dir, creating it
                        if it does not yet exist
  --new-plan-dir SLUG   sanitize SLUG to a kebab-case slug, create a plan dir
                        named `YYYY-MM-DD-<slug>` under the docs dir, and print
                        its absolute path

Build a plan's files by joining filenames to its dir yourself, e.g.
`<plan-dir>/TICKET.md`, `<plan-dir>/ARCHITECTURE.md`, `<plan-dir>/TASK-1.md`.
"""


class _Parser(argparse.ArgumentParser):
    def format_help(self) -> str:
        return HELP_TEXT

    def format_usage(self) -> str:
        return "usage: measured-notes [--new-plan-dir SLUG]\n"


def main(argv: list[str]) -> int:
    parser = _Parser(prog="measured-notes", add_help=False)
    parser.add_argument("-h", "--help", action="help")
    parser.add_argument("--new-plan-dir", dest="new_plan_dir", metavar="SLUG")

    args = parser.parse_args(argv)

    repo = session_lib.repo_dir()

    docs_location = session_lib.get_setting(repo, "docs-location")
    if docs_location is None:
        print(
            "measured-notes: docs-location is not set.\n"
            "\n"
            "Tell measured where to store plan docs by running one of:\n"
            "\n"
            "  measured-config --set docs-location XDG_STATE_HOME\n"
            "      Store docs in the default state dir (~/.local/state/…).\n"
            "\n"
            "  measured-config --set docs-location \"REPO: path/to/docs\"\n"
            "      Store docs in a subdirectory of the project repo.",
            file=sys.stderr,
        )
        return 1

    try:
        docs_dir = session_lib.resolve_docs_dir(repo, docs_location)
    except ValueError as e:
        print(f"measured-notes: {e}", file=sys.stderr)
        return 1

    docs_dir.mkdir(parents=True, exist_ok=True)

    if args.new_plan_dir is None:
        print(docs_dir)
        return 0

    try:
        print(session_lib.new_plan_dir(docs_dir, args.new_plan_dir))
    except ValueError as e:
        print(str(e), file=sys.stderr)
        return 1
    except FileExistsError as e:
        print(f"plan dir already exists: {e.filename}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
