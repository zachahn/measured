#!/usr/bin/env ruby

require "json"
require "fileutils"

input = JSON.parse($stdin.read)
session_id = input["session_id"]

cache_home = ENV["XDG_CACHE_HOME"] || File.join(Dir.home, ".cache")
session_dir = File.join(cache_home, "claude-measured", "session-#{session_id}")
