{
  "name": "weighed",
  "description": "Staged development workflow: orient, define, plan, build. Single-threaded, file-backed, with the user consulted at every fork.",
  "version": "1.2.8",
  "author": {
    "name": "Zach Ahn",
    "email": "measured-dev@zachahn.com"
  },
  "homepage": "https://github.com/zachahn/measured",
  "repository": "https://github.com/zachahn/measured",
  "license": "MIT",
  "keywords": [
    "workflow",
    "planning",
    "collaboration",
    "best-practices"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/auto-approve-plugin-reads.py"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|NotebookEdit|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/worktree-guard.py"
          }
        ]
      }
    ]
  }
}
