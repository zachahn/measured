#!/usr/bin/env python3
"""Manage a per-session note scratchpad keyed by Claude's PID + start time.

Each invocation selects one note and one action.

Note type (exactly one):
  --ticket-draft        Operate on the draft scratchpad (TICKET-DRAFT.md).
  --ticket              Operate on the finalized ticket (TICKET.md).

Action (exactly one):
  --read                Print the note's contents.
  --edit                Replace --old with --new in the note. Fails if --old
                        appears 0 times, or >1 times unless --replace-all.
  --append [TEXT]       Append TEXT to the note (reads stdin if TEXT is omitted).

Edit arguments (only valid with --edit):
  --old TEXT            Text to replace.
  --new TEXT            Replacement text.
  --replace-all         Replace every occurrence instead of requiring exactly one.

Shared logic lives in ../lib/note_lib.py.
"""

import argparse
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent / "lib"))
import note_lib as lib  # noqa: E402


def cmd_read(note_type: str) -> int:
    try:
        sys.stdout.write(lib.read_note(lib.session_dir(), note_type))
    except FileNotFoundError as e:
        raise SystemExit(str(e))
    return 0


def cmd_append(note_type: str, text: str | None) -> int:
    if text is None:
        text = sys.stdin.read()
    target = lib.append_note(lib.session_dir(), note_type, text)
    print(target)
    return 0


def cmd_edit(note_type: str, old: str, new: str, replace_all: bool) -> int:
    try:
        target, _ = lib.edit_note(lib.session_dir(), note_type, old, new, replace_all)
    except (ValueError, FileNotFoundError) as e:
        raise SystemExit(str(e))
    print(target)
    return 0


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        prog="measured-note",
        description="Per-Claude-session note scratchpad.",
    )

    note_group = parser.add_argument_group("note type (exactly one required)")
    note_group.add_argument(
        "--ticket-draft", dest="note", action="store_const", const=lib.NOTE_DRAFT
    )
    note_group.add_argument(
        "--ticket", dest="note", action="store_const", const=lib.NOTE_TICKET
    )

    action_group = parser.add_argument_group("action (exactly one required)")
    action_group.add_argument("--read", action="store_true")
    action_group.add_argument("--edit", action="store_true")
    action_group.add_argument("--append", nargs="?", const="", metavar="TEXT")

    edit_group = parser.add_argument_group("edit arguments (only valid with --edit)")
    edit_group.add_argument("--old", metavar="TEXT")
    edit_group.add_argument("--new", metavar="TEXT")
    edit_group.add_argument("--replace-all", action="store_true")

    args = parser.parse_args(argv)

    if args.note is None:
        parser.error("exactly one note type is required: --ticket-draft, --ticket")

    actions = [
        ("read", args.read),
        ("edit", args.edit),
        ("append", args.append is not None),
    ]
    chosen = [name for name, on in actions if on]
    if len(chosen) != 1:
        parser.error("exactly one action is required: --read, --edit, --append")

    if chosen[0] != "edit":
        if args.old is not None or args.new is not None or args.replace_all:
            parser.error("--old, --new, --replace-all are only valid with --edit")
    else:
        if args.old is None or args.new is None:
            parser.error("--edit requires both --old and --new")

    if args.read:
        return cmd_read(args.note)
    if args.edit:
        return cmd_edit(args.note, args.old, args.new, args.replace_all)
    if args.append is not None:
        return cmd_append(args.note, args.append or None)
    parser.print_usage(sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
