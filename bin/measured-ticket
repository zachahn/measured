#!/usr/bin/env python3
"""Manage a per-session ticket scratchpad keyed by Claude's PID + start time.

Subcommands (flag-style):
  --cache-step [TEXT]   Write a step as <ms-timestamp>.md; print the filename.
                        Reads stdin when TEXT is omitted.
  --list-steps          List step filenames in chronological order.
  --read-step NAME      Print the contents of the named step.
  --read-all-steps      Print all steps in chronological order, with headers.
  --set-ticket [TEXT]   Write TICKET.md in the session dir; refuses overwrite
                        unless --force is given. Reads stdin when TEXT omitted.
  --get-ticket          Print the contents of TICKET.md.

Shared logic lives in ../lib/ticket_lib.py.
"""

import argparse
import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent / "lib"))
import ticket_lib as lib  # noqa: E402


def cmd_cache_step(text: str | None) -> int:
    directory = lib.session_dir()
    if text is None:
        text = sys.stdin.read()
    target = lib.write_step(directory, text)
    print(target.name)
    return 0


def cmd_list_steps() -> int:
    for path in lib.step_files(lib.session_dir()):
        if path.name == lib.TICKET_FILENAME:
            continue
        print(path.name)
    return 0


def cmd_read_step(name: str) -> int:
    try:
        target = lib.resolve_step(lib.session_dir(), name)
    except (ValueError, FileNotFoundError) as e:
        raise SystemExit(str(e))
    sys.stdout.write(target.read_text())
    return 0


def cmd_read_all_steps() -> int:
    files = [p for p in lib.step_files(lib.session_dir()) if p.name != lib.TICKET_FILENAME]
    for i, path in enumerate(files):
        if i:
            sys.stdout.write("\n")
        body = path.read_text()
        sys.stdout.write(f"# {path.name}\n\n")
        sys.stdout.write(body)
        if not body.endswith("\n"):
            sys.stdout.write("\n")
    return 0


def cmd_set_ticket(text: str | None, force: bool) -> int:
    directory = lib.session_dir()
    if text is None:
        text = sys.stdin.read()
    try:
        target = lib.write_ticket(directory, text, force)
    except FileExistsError:
        raise SystemExit(
            f"{lib.TICKET_FILENAME} already exists; pass --force to overwrite"
        )
    print(target)
    return 0


def cmd_get_ticket() -> int:
    target = lib.ticket_path(lib.session_dir())
    if not target.is_file():
        raise SystemExit(f"{lib.TICKET_FILENAME} not set")
    sys.stdout.write(target.read_text())
    return 0


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        prog="measured-ticket",
        description="Per-Claude-session ticket scratchpad.",
    )
    parser.add_argument("--cache-step", nargs="?", const="", metavar="TEXT")
    parser.add_argument("--list-steps", action="store_true")
    parser.add_argument("--read-step", metavar="NAME")
    parser.add_argument("--read-all-steps", action="store_true")
    parser.add_argument("--set-ticket", nargs="?", const="", metavar="TEXT")
    parser.add_argument("--get-ticket", action="store_true")
    parser.add_argument("--force", action="store_true")
    args = parser.parse_args(argv)

    actions = [
        ("cache-step", args.cache_step is not None),
        ("list-steps", args.list_steps),
        ("read-step", args.read_step is not None),
        ("read-all-steps", args.read_all_steps),
        ("set-ticket", args.set_ticket is not None),
        ("get-ticket", args.get_ticket),
    ]
    chosen = [name for name, on in actions if on]
    if len(chosen) != 1:
        parser.error(
            "exactly one action is required: "
            "--cache-step, --list-steps, --read-step, --read-all-steps, "
            "--set-ticket, --get-ticket"
        )
    if args.force and chosen[0] != "set-ticket":
        parser.error("--force is only valid with --set-ticket")

    if args.cache_step is not None:
        return cmd_cache_step(args.cache_step or None)
    if args.list_steps:
        return cmd_list_steps()
    if args.read_step is not None:
        return cmd_read_step(args.read_step)
    if args.read_all_steps:
        return cmd_read_all_steps()
    if args.set_ticket is not None:
        return cmd_set_ticket(args.set_ticket or None, args.force)
    if args.get_ticket:
        return cmd_get_ticket()
    parser.print_usage(sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
