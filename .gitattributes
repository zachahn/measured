# Ensure shell scripts always have LF line endings
*.sh text eol=lf

# Common text files
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.gif binary

# Built from source/ via `rake build` — do not edit directly
skills/** linguist-generated=true
agents/** linguist-generated=true
